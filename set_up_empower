#!/usr/bin/env bash
# Container-native setup for Empower (ROS Humble / Python 3.10).
# - Installs Empower's Python dependencies into the active container Python.
# - Uses the devcontainer's existing Torch stack; detection runs through SAM3.
# - Resolves the SAM3 Hugging Face checkpoint into the local cache.
# - Creates images/ and output/ at the Empower repo root.
#
# Usage, from packages/empower:
#   ./set_up_empower
#
# Useful overrides:
#   PYTHON=/usr/bin/python3 ./set_up_empower
#   EMPOWER_INSTALL_DEPS=0 ./set_up_empower
#   EMPOWER_DOWNLOAD_WEIGHTS=0 ./set_up_empower
#   EMPOWER_SAM3_CHECKPOINT=/path/to/sam3.pt ./set_up_empower

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${PYTHON:-python3}"
REQ_FILE="${ROOT}/requirements-container.txt"
EMPOWER_INSTALL_DEPS="${EMPOWER_INSTALL_DEPS:-1}"
EMPOWER_DOWNLOAD_WEIGHTS="${EMPOWER_DOWNLOAD_WEIGHTS:-1}"

err() { echo "[ERROR] $*" >&2; exit 1; }

_python() {
  command -v "${PYTHON_BIN}" >/dev/null 2>&1 || err "Python not found: ${PYTHON_BIN}"
  "${PYTHON_BIN}" "$@"
}

_check_python() {
  _python - <<'PY'
import sys
if sys.version_info < (3, 10):
    raise SystemExit(
        f"[ERROR] Empower devcontainer setup expects Python >= 3.10; found {sys.version.split()[0]}"
    )
print(f"[INFO] Using Python {sys.version.split()[0]} at {sys.executable}")
PY
}

_pip_user_flag() {
  if [ "$(id -u)" -eq 0 ] || [ -n "${VIRTUAL_ENV:-}" ]; then
    return 0
  fi
  _python - <<'PY'
import os
import sysconfig
purelib = sysconfig.get_paths().get("purelib", "")
raise SystemExit(0 if purelib and os.access(purelib, os.W_OK) else 1)
PY
}

_pip() {
  local -a user_flag=()
  if ! _pip_user_flag; then
    user_flag=(--user)
    export PATH="${HOME}/.local/bin:${PATH}"
  fi
  _python -m pip install "${user_flag[@]}" "$@"
}

_install_deps() {
  [ -f "${REQ_FILE}" ] || err "Missing requirements file: ${REQ_FILE}"

  echo ""
  echo "[INFO] Installing Empower dependencies into the active Python environment..."
  _pip --upgrade "pip<26" wheel
  _pip -r "${REQ_FILE}"
  if [ -d "${ROOT}/../sam3" ]; then
    _pip -e "${ROOT}/../sam3"
  else
    echo "[WARN] Local SAM3 package not found at ${ROOT}/../sam3"
  fi

  if ! _python - <<'PY'
import spacy
spacy.load("en_core_web_sm")
PY
  then
    echo "[INFO] Downloading spaCy model en_core_web_sm..."
    _python -m spacy download en_core_web_sm
  fi
}

_verify_python_deps() {
  echo ""
  echo "[INFO] Verifying Empower imports..."
  (cd "${ROOT}/src" && _python - <<'PY')
import importlib

modules = [
    "torch",
    "torchvision",
    "spacy",
    "open3d",
    "cv2",
    "numpy",
    "sam3",
    "models",
    "loader",
    "detection",
]

for name in modules:
    module = importlib.import_module(name)
    print(f"[OK] {name} {getattr(module, '__version__', '')}".rstrip())

import spacy
spacy.load("en_core_web_sm")
print("[OK] spaCy model en_core_web_sm")
PY
}

_warm_sam3_model() {
  echo ""
  echo "[INFO] Checking SAM3 checkpoint..."
  (cd "${ROOT}/src" && _python - <<'PY')
import os

from huggingface_hub import hf_hub_download

checkpoint = os.environ.get("EMPOWER_SAM3_CHECKPOINT")
if checkpoint:
    print(f"[OK] Using EMPOWER_SAM3_CHECKPOINT={checkpoint}")
else:
    token_present = bool(
        os.environ.get("HF_TOKEN")
        or os.environ.get("HUGGINGFACE_HUB_TOKEN")
        or os.environ.get("HUGGING_FACE_HUB_TOKEN")
    )
    for filename in ("config.json", "sam3.pt"):
        try:
            path = hf_hub_download(
                repo_id="facebook/sam3",
                filename=filename,
                local_files_only=not token_present,
            )
        except Exception as exc:
            if token_present:
                raise
            raise SystemExit(
                "[ERROR] SAM3 checkpoint is not cached and HF_TOKEN is not set. "
                "Export HF_TOKEN or set EMPOWER_SAM3_CHECKPOINT=/path/to/sam3.pt."
            ) from exc
        print(f"[OK] SAM3 {filename}: {path}")

from models import SAM3Detector

detector = SAM3Detector(checkpoint_path=checkpoint)
print(f"[OK] SAM3 detector initialized on {detector.device}")
PY
}

_download_model_weights() {
  echo ""
  echo "[INFO] Model weights (SAM3)..."
  _warm_sam3_model
}

_check_python
mkdir -p "${ROOT}/images" "${ROOT}/output"

if [ "${EMPOWER_INSTALL_DEPS}" = "1" ]; then
  _install_deps
  _verify_python_deps
else
  echo "[INFO] Skipping Python dependency install because EMPOWER_INSTALL_DEPS=0."
fi

if [ "${EMPOWER_DOWNLOAD_WEIGHTS}" = "1" ]; then
  _download_model_weights
else
  echo "[INFO] Skipping model downloads because EMPOWER_DOWNLOAD_WEIGHTS=0."
fi

echo ""
echo "[OK] Empower repo is ready at ${ROOT}"
echo "  cd ${ROOT}/src"
echo "  python3 prepare_local_data.py order_by_height 5 0"
echo "  python3 models_cacher.py order_by_height"
echo "  python3 execute_task.py"
echo ""
echo "[NOTE] Export MISTRAL_API_KEY or OPENAI_API_KEY before running LLM agents."
